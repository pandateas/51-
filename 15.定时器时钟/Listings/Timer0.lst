line level    source

   1          //初始化定时器,开始计时
   2          //计时满后跳转到 main 中的 interrupt 1 函数
   3          //随后执行完interrupt 1 的指令后在返回接着执行计时
   4          //执行完一次 Timer0_Init 大约是 1ms
   5          
   6          
   7          
   8          #include <REGX52.H>
   9          
  10          void Timer0_Init()//@1ms
  11          {
  12   1              //TMOD = 0x01;//0000 0001//当要是用两个定时器时这样写不行
  13   1          
  14   1          TMOD &= 0xF0;//单片机定时器启动模式,默认启动定时器1
  15   1                      //但是这种写法不是很好,容易影响到定时器2
  16   1          TMOD |= 0x01;
  17   1           
  18   1          
  19   1          TF0 = 0;//当计数满了后归1中断计时
  20   1                  //Timer OverFlow//溢出标志位,需要手动清零
  21   1          
  22   1          
  23   1              TR0 = 1;//Timer_Run//定时器启动开关,开启了才能用
  24   1          
  25   1          
  26   1          TH0 = 64615 / 256;//拿出高八位 //相当于拿出,十百位
  27   1          TL0 = 64615 % 256 + 1;//拿出低八位 //相当于拿出个位
  28   1              //通式:起始时间 / 256(2的16位)
  29   1          //     起始时间 % 256
  30   1          //TH0和TL0两个互相打配合,来完成计时的过程
  31   1          
  32   1          
  33   1          ET0 = 1;//Enable Timer0 Interrupt//定时器使能中断器
  34   1          //定时器中断开关,开启后计数满会执行中断                               
  35   1          //当ET0 = 0时就算定时器溢出了也不会触发中断
  36   1          
  37   1          
  38   1          EA = 1;//Enable All Interrupts
  39   1          //总开关,允许所有的中断
  40   1          
  41   1          PT0 = 0;//Priority Timer0
  42   1          //设置定时器0的中断优先级默认为0//低优先级
  43   1          
  44   1          
  45   1          
  46   1          
  47   1      }
  48          
  49          
  50          
  51          
