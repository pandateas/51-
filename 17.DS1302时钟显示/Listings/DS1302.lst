   1          #include <REGX52.H>
   2          
   3          sbit DS1302_SCLK = P3^6;// DS1302时钟引脚,通信的节拍器
   4          sbit DS1302_IO   = P3^4;// 双向通信引脚,用来传输数据,与计时器通信的引脚
   5          sbit DS1302_CE   = P3^5;// DS1302的使能开关,置1开启,置0关闭
   6           
   7          #define DS1302_SECOND 0x80
   8          #define DS1302_MINUTE 0x82
   9          #define DS1302_HOUR   0x84
  10          #define DS1302_DATE   0x86
  11          #define DS1302_MONTH  0x88
  12          #define DS1302_DAY    0x8A
  13          #define DS1302_YEAR   0x8C
  14          #define DS1302_WP     0x8E
  15          
  16          unsigned char i;
  17          unsigned char DS1302_Time[] = {26,3,25,19,10,55,2};
  18          //这里以十进制显示的日期时间信息,要存进单片机里必须
  19          //以BCD码的形式写给单片机,为什么用BCD码?因为DS1302的
  20          //设计可以理解它都是四个寄存器为一组表示0~9的十个数字
  21          //使用BCD码正好能够用高四位、低四位,来存储0~9的信息
  22          
  23          
  24          
  25          //初始化DS1302,打开开关使能DS1302
  26          void DS1302_Init(void)
  27          {
  28   1          DS1302_CE = 0;     //总开关关闭
  29   1          DS1302_SCLK = 0;   //时钟脉冲关闭
  30   1      }
  31          
  32          
  33          
  34          //单片机的读写操作都要通过下面的WriteByte,ReadByte函数来进行读写
  35          //都需要先根据顺序,先来的是寻址,后来的是数据来进行读写操作
  36          //读写需要有上升沿,都是从八位寄存器的最低位开始往高位进行寻址,即从0~7
  37          
  38          //在Data里进行的|=操作你有没有觉得很奇怪?如果或等于是开关的话,从最低位
  39          //打开到最高位的开关,但是或等于的特性是只改变选中的位置,而不改变其他的位置
  40          //那么前面打开的开关怎么办?
  41          //答:在Data里进行的操作实际上不是打开开关,而是写入数据
  42          //单片机只能够逐位读取信息,所以在Data里要把二进制的信息拆分成8个部分逐一写入
  43          //而或等于正是保证从低位到高位写入的数据不会被修改,能够正常的向后写入
  44          //同理Command进行的&=操作也是逐一写入八位二进制数据,来规定我要往哪个寄存器写入数据
  45          
  46          //电脑向单片机写入,先对目标寄存器,后写入数据
  47          void DS1302_WriteByte(unsigned char Command,unsigned char Data)
  48          {
  49   1          DS1302_CE = 1;//使用前启动,表示开始和芯片通信
  50   1          
  51   1          for(i = 0;i < 8;i ++)
  52   1          {
  53   2            DS1302_IO = Command&(0x01<<i);//保留第i位,其余强制置0
  54   2                                          //通过&符号表示只操作这一位
C51 COMPILER V9.60.7.0   DS1302                                                            03/25/2026 16:26:02 PAGE 2   

  55   2            DS1302_SCLK = 1;//脉冲时钟打开,上升沿寻址
  56   2            DS1302_SCLK = 0;//脉冲时钟关闭,下降沿完成寻址
  57   2          }   
  58   1          
  59   1           for(i = 0;i < 8;i ++)
  60   1          {
  61   2            DS1302_IO = Data&(0x01<<i);//保留第i位,其余置0
  62   2            DS1302_SCLK = 1;//脉冲打开,上升沿写入
  63   2            DS1302_SCLK = 0;//脉冲关闭,完成数据输入
  64   2          }   
  65   1          
  66   1           DS1302_CE = 0;//使用后关闭,通信结束
  67   1      }
  68          
  69          
  70          
  71          
  72          
  73          //单片机读取已经被写入进来的数据
  74          unsigned char DS1302_ReadByte(unsigned char Command)
  75          {
  76   1          unsigned char i,Data = 0x00;
  77   1              Command |= 0x01;//将读位置1,进入读模式
  78   1          DS1302_CE = 1;  //打开DS1302开关
  79   1          
  80   1          //根据DS1302数据手册可知,在读模式下的寻址是用下降沿来激活的
  81   1          for(i = 0;i < 8;i ++)
  82   1          {
  83   2            DS1302_IO = Command&(0x01<<i);
  84   2            DS1302_SCLK = 0;//下降沿选定寄存器
  85   2            DS1302_SCLK = 1;//上升沿关闭寻址
  86   2          }   
  87   1          
  88   1          for(i = 0;i < 8;i ++)
  89   1          {
  90   2              DS1302_SCLK = 1;//上升沿读取寄存器中的数据
  91   2              DS1302_SCLK = 0;//下降沿完成读取操作  
  92   2              if(DS1302_IO){Data |= (0x01<<i);}
  93   2          }
  94   1         
  95   1              DS1302_CE = 0;//关闭DS1302开关
  96   1          DS1302_IO = 0;
  97   1              return Data;//返回真正需要表示的十进制日期、时间数字
  98   1      }
  99          
