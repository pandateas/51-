 105          
 106          //DS1302设置时间,写入单片机
 107          void DS1302_SetTime(void)
 108          {
 109   1          //十进制转换为BCD码
 110   1              DS1302_WriteByte(DS1302_WP,0x00);//关闭写入保护
 111   1          
 112   1          //下面是要存入的信息,先指定要存入的是什么位,然后再写入数据
 113   1              DS1302_WriteByte(DS1302_YEAR,  DS1302_Time[0]/10*16 + DS1302_Time[0]%10);
 114   1              DS1302_WriteByte(DS1302_MONTH, DS1302_Time[1]/10*16 + DS1302_Time[1]%10);
 115   1              DS1302_WriteByte(DS1302_DATE,  DS1302_Time[2]/10*16 + DS1302_Time[2]%10);
 116   1              DS1302_WriteByte(DS1302_HOUR,  DS1302_Time[3]/10*16 + DS1302_Time[3]%10);
C51 COMPILER V9.60.7.0   DS1302                                                            03/25/2026 16:26:02 PAGE 3   

 117   1              DS1302_WriteByte(DS1302_MINUTE,DS1302_Time[4]/10*16 + DS1302_Time[4]%10);
 118   1              DS1302_WriteByte(DS1302_SECOND,DS1302_Time[5]/10*16 + DS1302_Time[5]%10);
 119   1              DS1302_WriteByte(DS1302_DAY,   DS1302_Time[6]/10*16 + DS1302_Time[6]%10);
 120   1          
 121   1              DS1302_WriteByte(DS1302_WP,0x80);//打开写入保护
 122   1      }
 123          
 124          
 125          
 126          //单片机自身读取已经写入的时间
 127          void DS1302_ReadTime(void)
 128          {
 129   1              unsigned char temp;
 130   1              
 131   1          //将原本转换成单片机能够读取的BCD码的十进制数,转换成真正需要显示的正确十进制数
 132   1              temp = DS1302_ReadByte(DS1302_YEAR);
 133   1              DS1302_Time[0] = temp/16*10 + temp%16;
 134   1              temp = DS1302_ReadByte(DS1302_MONTH);
 135   1              DS1302_Time[1] = temp/16*10 + temp%16;
 136   1              temp = DS1302_ReadByte(DS1302_DATE);
 137   1              DS1302_Time[2] = temp/16*10 + temp%16;
 138   1              temp = DS1302_ReadByte(DS1302_HOUR);
 139   1              DS1302_Time[3] = temp/16*10 + temp%16;
 140   1              temp = DS1302_ReadByte(DS1302_MINUTE);
 141   1              DS1302_Time[4] = temp/16*10 + temp%16;
 142   1              temp = DS1302_ReadByte(DS1302_SECOND);
 143   1              DS1302_Time[5] = temp/16*10 + temp%16;
 144   1              temp = DS1302_ReadByte(DS1302_DAY);
 145   1              DS1302_Time[6] = temp/16*10 + temp%16;
 146   1      }
