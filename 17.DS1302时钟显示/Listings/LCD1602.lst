  57   1              LCD_WriteCommand(0x38);//八位数据接口，两行显示，5*7点阵
  58   1              LCD_WriteCommand(0x0c);//显示开，光标关，闪烁关
  59   1              LCD_WriteCommand(0x06);//数据读写操作后，光标自动加一，画面不动
  60   1              LCD_WriteCommand(0x01);//光标复位，清屏
  61   1      }
