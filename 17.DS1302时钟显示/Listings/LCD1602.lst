 193          void LCD_ShowSignedNum(unsigned char Line,unsigned char Column,int Number,unsigned char Length)
 194          {
 195   1              unsigned char i;
 196   1              unsigned int Number1;
 197   1              LCD_SetCursor(Line,Column);
 198   1              if(Number>=0)
