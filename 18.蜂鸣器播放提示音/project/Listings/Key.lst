line level    source

   1          //当按下独立按键后,能够实现记录当前按下的独立按键标号
   2          //并将标号转递给KeyNumber并且返回标号
   3          //方便在main函数中再次使用
   4          
   5          
   6          
   7          
   8          #include <REGX52.H>
   9          #include "Delay.h"
  10          
  11          
  12          /*
  13          * @brief    获取独立按键的密码
  14          * @param    无
  15          * @retval   按下按键的键码,范围0~4,无按键时返回0
  16          */
  17          
  18          
  19          //返回值类型:unsigned char
  20          unsigned char Key()
  21          {
  22   1          unsigned char KeyNumber = 0;
  23   1          
  24   1          
  25   1              //P3_0 ~ 3是独立按键,和LED一样,0的时候是上电/按下
  26   1          if(P3_1 == 0){Delay(20);while(P3_1==0);Delay(20);KeyNumber=1;} 
  27   1          if(P3_0 == 0){Delay(20);while(P3_0==0);Delay(20);KeyNumber=2;}
  28   1          if(P3_2 == 0){Delay(20);while(P3_2==0);Delay(20);KeyNumber=3;}
  29   1          if(P3_3 == 0){Delay(20);while(P3_3==0);Delay(20);KeyNumber=4;}
  30   1          
  31   1          return KeyNumber;
  32   1          
  33   1          
  34   1      }


