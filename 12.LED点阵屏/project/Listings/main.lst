 241          };
 242          
 243          // 点阵屏显示爱心函数（逐行扫描显示）
 244          void Display_Heart()
 245          {
 246              unsigned char i;
 247              for(i = 0; i < 8; i++)
 248              {
 249                  HC595_SendByte(Heart[i]);  // 发送当前行的显示数据
 250                  P0 = ~(0x80 >> i);         // 选通当前行（共阴点阵，列低电平有效）
 251                  Delay(1);                  // 保持显示，消影
 252                  P0 = 0xFF;                 // 关闭当前行，消除余辉
 253              }
 254          }
 255          
 256          // 主函数：循环显示爱心
 257          void main(void)
 258          {
 259              yw = 0;  // 初始化移位时钟
 260              cs = 0;  // 初始化锁存时钟
 261              while(1)
 262              {
 263                  Display_Heart();  // 持续显示爱心
