 191          /*
 192          #include "REGX52.H"  // 替换为你的RGXS52.H头文件
 193          
 194          // 定义74HC595与单片机的连接引脚（沿用你之前的引脚定义）
 195          sbit sjw  = P3^4;  // 74HC595串行数据输入（SER）
 196          sbit yw   = P3^6;  // 74HC595移位时钟（SRCLK）SCK
 197          sbit cs   = P3^5;  // 74HC595锁存时钟（RCLK）RCK
 198          
 199          // 延时函数（消影+稳定显示，适配11.0592MHz晶振）
 200          void Delay(unsigned int xms)
 201          {
 202              unsigned char i, j;
 203              while(xms--)
 204              {
 205                  i = 2;
 206                  j = 199;
 207                  do
 208                  {
 209                      while(--j);
 210                  } while(--i);
 211              }
 212          }
 213          
 214          // 向74HC595发送1字节数据（标准时序，高位先行）
 215          void HC595_SendByte(unsigned char Byte)
 216          {
 217              unsigned char i;
 218              for(i = 0; i < 8; i++)
 219              {
 220                  sjw = (Byte >> (7 - i)) & 0x01;  // 取当前最高位
 221                  yw = 0;                          // 移位时钟拉低
 222                  yw = 1;                          // 上升沿移入数据
 223                  yw = 0;                          // 拉低复位
 224              }
 225              cs = 0;           // 锁存时钟拉低
 226              cs = 1;           // 上升沿锁存输出
 227              cs = 0;           // 拉低复位
 228          }
 229          
 230          // 8x8点阵爱心字模（共阴点阵，每一行对应1字节，0=灭，1=亮）
 231          // 行0到行7的显示数据，按爱心形状定义
 232          unsigned char Heart[8] = {
 233              0x00,  // 行0：00000000
 234              0x3C,  // 行1：00111100
 235              0x7E,  // 行2：01111110
 236              0xFF,  // 行3：11111111
 237              0xFF,  // 行4：11111111
 238              0x7E,  // 行5：01111110
 239              0x3C,  // 行6：00111100
 240              0x00   // 行7：00000000
