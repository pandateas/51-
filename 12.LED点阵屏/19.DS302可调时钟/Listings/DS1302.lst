line level    source

   1          /*
   2          DS1302是单片机外部时钟芯片,拥有计时器的基本功能
   3          在使用的时候只需要给他设置好时分秒年月日啥的
   4          以及十进制到BCD的转译啥的就能够用了
   5          千万不要在引入单片机内部时钟,不然会屏闪
   6          (别问我怎么知道的qwq)
   7          */
   8          
   9          
  10          
  11          
  12          
  13          
  14          #include <REGX52.H>
  15          
  16          sbit DS1302_SCLK = P3^6;// DS1302时钟引脚,通信的节拍器
  17          sbit DS1302_IO   = P3^4;// 双向通信引脚,用来传输数据,与计时器通信的引脚
  18          sbit DS1302_CE   = P3^5;// DS1302的使能开关,置1开启,置0关闭
  19           
  20          #define DS1302_SECOND 0x80
  21          #define DS1302_MINUTE 0x82
  22          #define DS1302_HOUR   0x84
  23          #define DS1302_DATE   0x86
  24          #define DS1302_MONTH  0x88
  25          #define DS1302_DAY    0x8A
  26          #define DS1302_YEAR   0x8C
  27          #define DS1302_WP     0x8E
  28          
  29          unsigned char i;
  30          unsigned char DS1302_Time[];
  31          //这里以十进制显示的日期时间信息,要存进单片机里必须
  32          //以BCD码的形式写给单片机,为什么用BCD码?因为DS1302的
  33          //设计可以理解它都是四个寄存器为一组表示0~9的十个数字
  34          //使用BCD码正好能够用高四位、低四位,来存储0~9的信息
  35          
  36          
  37          
  38          //初始化DS1302,打开开关使能DS1302
  39          void DS1302_Init(void)
  40          {
  41   1          DS1302_CE = 0;     //总开关关闭
  42   1          DS1302_SCLK = 0;   //时钟脉冲关闭
  43   1      }
  44          
  45          
  46          
  47          //单片机的读写操作都要通过下面的WriteByte,ReadByte函数来进行读写
  48          //都需要先根据顺序,先来的是寻址,后来的是数据来进行读写操作
  49          //读写需要有上升沿,都是从八位寄存器的最低位开始往高位进行寻址,即从0~7
  50          
  51          //在Data里进行的|=操作你有没有觉得很奇怪?如果或等于是开关的话,从最低位
  52          //打开到最高位的开关,但是或等于的特性是只改变选中的位置,而不改变其他的位置
  53          //那么前面打开的开关怎么办?
  54          //答:在Data里进行的操作实际上不是打开开关,而是写入数据
C51 COMPILER V9.57.0.0   DS1302                                                            03/26/2026 20:35:11 PAGE 2   

  55          //单片机只能够逐位读取信息,所以在Data里要把二进制的信息拆分成8个部分逐一写入
  56          //而或等于正是保证从低位到高位写入的数据不会被修改,能够正常的向后写入
  57          //同理Command进行的&=操作也是逐一写入八位二进制数据,来规定我要往哪个寄存器写入数据
  58          
  59          //电脑向单片机写入,先对目标寄存器,后写入数据
  60          void DS1302_WriteByte(unsigned char Command,unsigned char Data)
  61          {
  62   1          DS1302_CE = 1;//使用前启动,表示开始和芯片通信
  63   1          
  64   1          for(i = 0;i < 8;i ++)
  65   1          {
  66   2            DS1302_IO = Command&(0x01<<i);//保留第i位,其余强制置0
  67   2                                          //通过&符号表示只操作这一位
  68   2            DS1302_SCLK = 1;//脉冲时钟打开,上升沿寻址
  69   2            DS1302_SCLK = 0;//脉冲时钟关闭,下降沿完成寻址
  70   2          }   
  71   1          
  72   1           for(i = 0;i < 8;i ++)
  73   1          {
  74   2            DS1302_IO = Data&(0x01<<i);//保留第i位,其余置0
  75   2            DS1302_SCLK = 1;//脉冲打开,上升沿写入
  76   2            DS1302_SCLK = 0;//脉冲关闭,完成数据输入
  77   2          }   
  78   1          
  79   1           DS1302_CE = 0;//使用后关闭,通信结束
  80   1      }
  81          
  82          
  83          
  84          
  85          
  86          //单片机读取已经被写入进来的数据
  87          unsigned char DS1302_ReadByte(unsigned char Command)
  88          {
  89   1          unsigned char i,Data = 0x00;
  90   1              Command |= 0x01;//将读位置1,进入读模式
  91   1          DS1302_CE = 1;  //打开DS1302开关
  92   1          
  93   1          //根据DS1302数据手册可知,在读模式下的寻址是用下降沿来激活的
  94   1          for(i = 0;i < 8;i ++)
  95   1          {
  96   2            DS1302_IO = Command&(0x01<<i);
  97   2            DS1302_SCLK = 0;//下降沿选定寄存器
  98   2            DS1302_SCLK = 1;//上升沿关闭寻址
  99   2          }   
 100   1          
 101   1          for(i = 0;i < 8;i ++)
 102   1          {
 103   2              DS1302_SCLK = 1;//上升沿读取寄存器中的数据
 104   2              DS1302_SCLK = 0;//下降沿完成读取操作  
 105   2              if(DS1302_IO){Data |= (0x01<<i);}
 106   2          }
 107   1         
 108   1              DS1302_CE = 0;//关闭DS1302开关
 109   1          DS1302_IO = 0;
 110   1              return Data;//返回真正需要表示的十进制日期、时间数字
 111   1      }
