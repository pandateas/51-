 118          
 119          //DS1302设置时间,写入单片机
 120          void DS1302_SetTime(void)
 121          {
 122   1          //十进制转换为BCD码
 123   1              DS1302_WriteByte(DS1302_WP,0x00);//关闭写入保护
 124   1          
 125   1          //下面是要存入的信息,先指定要存入的是什么位,然后再写入数据
 126   1              DS1302_WriteByte(DS1302_YEAR,  DS1302_Time[0]/10*16 + DS1302_Time[0]%10);
 127   1              DS1302_WriteByte(DS1302_MONTH, DS1302_Time[1]/10*16 + DS1302_Time[1]%10);
 128   1              DS1302_WriteByte(DS1302_DATE,  DS1302_Time[2]/10*16 + DS1302_Time[2]%10);
 129   1              DS1302_WriteByte(DS1302_HOUR,  DS1302_Time[3]/10*16 + DS1302_Time[3]%10);
 130   1              DS1302_WriteByte(DS1302_MINUTE,DS1302_Time[4]/10*16 + DS1302_Time[4]%10);
 131   1              DS1302_WriteByte(DS1302_SECOND,DS1302_Time[5]/10*16 + DS1302_Time[5]%10);
 132   1              DS1302_WriteByte(DS1302_DAY,   DS1302_Time[6]/10*16 + DS1302_Time[6]%10);
 133   1          
 134   1              DS1302_WriteByte(DS1302_WP,0x80);//打开写入保护
 135   1      }
 136          
 137          
 138          
 139          //单片机自身读取已经写入的时间
 140          void DS1302_ReadTime(void)
 141          {
 142   1              unsigned char temp;
 143   1              
 144   1          //将原本转换成单片机能够读取的BCD码的十进制数,转换成真正需要显示的正确十进制数
 145   1              temp = DS1302_ReadByte(DS1302_YEAR);
 146   1              DS1302_Time[0] = temp/16*10 + temp%16;
 147   1              temp = DS1302_ReadByte(DS1302_MONTH);
 148   1              DS1302_Time[1] = temp/16*10 + temp%16;
 149   1              temp = DS1302_ReadByte(DS1302_DATE);
 150   1              DS1302_Time[2] = temp/16*10 + temp%16;
 151   1              temp = DS1302_ReadByte(DS1302_HOUR);
 152   1              DS1302_Time[3] = temp/16*10 + temp%16;
 153   1              temp = DS1302_ReadByte(DS1302_MINUTE);
 154   1              DS1302_Time[4] = temp/16*10 + temp%16;
 155   1              temp = DS1302_ReadByte(DS1302_SECOND);
 156   1              DS1302_Time[5] = temp/16*10 + temp%16;
 157   1              temp = DS1302_ReadByte(DS1302_DAY);
 158   1              DS1302_Time[6] = temp/16*10 + temp%16;
 159   1      }
 160          
 161          
 162          /*
 163          DS1302写入数据小原理
 164          上升沿下降沿,把上升沿想象成开门,下降沿想象成关门
 165          有人敲门那么寄存器就会开门接客,关门了那么就会准备迎接下一个客人
 166          
 167          关于DS1302怎么区分Command和Data两种数据:
 168          Command:表示我现在指定某一位,准备往这一位写入数据
 169          Data:表示我要往这一位写入的数据
 170          这两个都是人起的名字,实际上单片机并不认识Command和Data
 171          单片机是靠进来的数据的先后顺序来判断哪一个是寻址指令,哪一个是数据
 172          单片机强制规定:先进来的一定是寻址指令,后进来的一定是数据
 173          
 174          Command操作的实际上是《DS1302中文手册》第八页表三的寄存器
 175          操作的是年月日时分秒星期这些东西,来通过寻址指定我要往哪个位写入数据
 176          */


